# ============================================
# MONGODB CONNECTION
# ============================================

# Option 1: LOCAL MONGODB (Development)
# MONGODB_URI=mongodb://localhost:27017/claimease

# Option 2: MONGODB ATLAS (Cloud - Recommended)
# Instructions:
# 1. Go to https://cloud.mongodb.com
# 2. Create a free cluster
# 3. Create a database user (e.g., claimease_admin)
# 4. Add your IP to Network Access
# 5. Click "Connect" → "Drivers" → Copy the connection string
# 6. Replace <USERNAME>, <PASSWORD>, and <CLUSTER> below

# MONGODB_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER>.mongodb.net/claimease?retryWrites=true&w=majority

# Note: Replace <USERNAME>, <PASSWORD>, and <CLUSTER> with your actual MongoDB Atlas credentials
# NEVER commit real credentials to version control

# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3001
NODE_ENV=development

# ============================================
# JWT AUTHENTICATION
# ============================================
# IMPORTANT: Generate a strong random secret for each environment!
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=INSECURE_CHANGE_ME_OR_APP_WILL_FAIL

# Token expiration (1 hour = 1h for access token, use refresh tokens for session continuity)
JWT_EXPIRES_IN=24h

# ============================================
# DEMO DATA CONFIGURATION
# ============================================
# Set to 'true' to automatically create demo organizations and users on first run
SEED_DEMO_DATA=true

# Demo passwords (if not set, random ones will be generated and logged)
DEMO_PATIENT_PASSWORD=patient123
DEMO_HOSPITAL_PASSWORD=hospital123
DEMO_INSURANCE_PASSWORD=insurance123

# ============================================
# SECURITY (Production)
# ============================================

# Allowed CORS origins (comma-separated)
# CORS_ORIGINS=https://app.claimease.com,https://hospital.claimease.com

# Rate limiting per IP
# RATE_LIMIT_WINDOW_MS=15000
# RATE_LIMIT_MAX_REQUESTS=100
